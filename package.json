{
  "name": "tab-completion",
  "displayName": "Tab Completion",
  "description": "Tab completion for vscode",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.116.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "Tab Completion",
      "properties": {
        "tab-completion.fireworksApiKey": {
          "type": "string",
          "default": "",
          "description": "Fireworks AI API key"
        },
        "tab-completion.groqApiKey": {
          "type": "string",
          "default": "",
          "description": "Groq API key"
        },
        "tab-completion.openrouterApiKey": {
          "type": "string",
          "default": "",
          "description": "OpenRouter API key (default)"
        },
        "tab-completion.model": {
          "type": "string",
          "default": "qwen/qwen3-32",
          "description": "AI model to use for completions"
        },
        "tab-completion.maxTokens": {
          "type": "number",
          "default": 500,
          "minimum": 50,
          "maximum": 5000,
          "description": "Maximum tokens to generate"
        },
        "tab-completion.completionCacheMaxEntries": {
          "type": "number",
          "default": 100,
          "minimum": 10,
          "maximum": 1000,
          "description": "Maximum entries in compition cache"
        },
        "tab-completion.completionCacheTtlMs": {
          "type": "number",
          "default": 30000,
          "minimum": 5000,
          "maximum": 120000,
          "description": "Completion Cache TTL in seconds"
        },
        "tab-completion.lspCacheMaxEntries": {
          "type": "number",
          "default": 100,
          "minimum": 10,
          "maximum": 1000,
          "description": "Maximum entries in compition cache"
        }
      }
    },
    "commands": [
      {
        "command": "tab-completion.helloWorld",
        "title": "Hello World"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.116.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "crypto": "^1.0.1"
  }
}
